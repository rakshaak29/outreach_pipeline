# ─────────────────────────────────────────────────────────────
#  Automated Outreach Pipeline — Environment Variable Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Ocean.io API token (Account Settings → API Tokens)
OCEAN_API_KEY=your_value_here

# Prospeo API key (Account Settings → API)
PROSPEO_API_KEY=your_value_here

# ── Optional overrides ─────────────────────────────────────────
# Ocean.io v3 base URL (do not change unless instructed by Ocean.io)
# Lookalike endpoint: POST {OCEAN_BASE_URL}/search/companies
# Full API spec:      GET  https://api.ocean.io/openapi.json
OCEAN_BASE_URL=your_value_here

# Prospeo base URL (do not change unless instructed by Prospeo)
PROSPEO_BASE_URL=your_value_here

# Maximum similar companies to fetch per pipeline run (default: 10)
MAX_SIMILAR_COMPANIES=your_value_here

# Maximum contacts to fetch per company (default: 5)
MAX_CONTACTS_PER_COMPANY=your_value_here

# HTTP retry settings
RETRY_MAX_ATTEMPTS=your_value_here
RETRY_BACKOFF_FACTOR=your_value_here

# Output file path (relative to project root)
OUTPUT_FILE=your_value_here

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=your_value_here
